---
/**
 * Intro.astro - écran d'intro plein écran, joué UNE SEULE FOIS par session,
 * au premier chargement. Pilotée par intro.ts.
 *
 * Principes :
 *  - Caché par défaut (hidden). Le script l'affiche seulement s'il faut le
 *    jouer (première visite de la session, mouvement autorisé, JS actif).
 *    → aucun blocage du contenu si JS absent ou reduced-motion.
 *  - Skippable (clic / scroll / touche) et auto-fin après l'animation.
 *  - Le nom affiché reprend le hero (même histoire typographique).
 */
---

<div class="intro" data-intro aria-hidden="true">
  <div class="intro__inner">
    <span class="intro__name">
      Chew<span class="intro__sig">back<span>k</span></span>
    </span>
  </div>
  <button class="intro__skip" type="button" data-intro-skip>Passer</button>
</div>

<!-- Suppression synchrone AVANT peinture si l'intro ne doit pas jouer
     (déjà vue dans la session, reduced-motion, ou hors home) → évite tout
     flash de l'overlay sur les visites répétées. -->
<script is:inline>
  (function () {
    try {
      var seen = sessionStorage.getItem("cbk_intro_seen") === "1";
      var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      var home = location.pathname === "/";
      if (seen || reduce || !home) {
        var n = document.querySelector("[data-intro]");
        if (n) n.style.display = "none";
      }
    } catch (e) {}
  })();
</script>

<script>
  import { bootstrapIntro } from "../scripts/intro";
  bootstrapIntro();
</script>

<style>
  /* Visible UNIQUEMENT si JS est actif : sans JS, pas d'overlay (le contenu
     reste accessible). Avec JS, le script décide de jouer l'intro ou de la
     retirer instantanément (non-home / déjà vue / reduced-motion). */
  .intro {
    display: none;
  }
  :global(html.js) .intro {
    position: fixed;
    inset: 0;
    z-index: 200; /* au-dessus de tout, y compris la nav */
    display: grid;
    place-items: center;
    background: var(--c-bg);
  }

  .intro__inner {
    padding-inline: var(--container-pad);
    overflow: hidden;
  }

  .intro__name {
    display: block;
    font-family: var(--font-display);
    font-weight: 500;
    line-height: 0.9;
    letter-spacing: -0.04em;
    font-size: clamp(3rem, 14vw, 11rem);
    color: var(--c-ink);
    white-space: nowrap;
  }
  .intro__sig > span {
    color: var(--c-accent);
  }

  .intro__skip {
    position: absolute;
    bottom: var(--sp-8);
    right: var(--sp-8);
    padding: var(--sp-2) var(--sp-4);
    background: transparent;
    color: var(--c-ink-muted);
    border: 1px solid var(--c-line);
    border-radius: var(--r-sm);
    font-size: var(--fs-step--1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .intro__skip:hover {
    color: var(--c-ink);
    border-color: var(--c-accent);
  }
</style>
