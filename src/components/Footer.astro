---
/**
 * Footer.astro - présent sur toutes les pages via BaseLayout.
 * Obligations du brief : lien « Mentions légales » + mention TVA visibles partout.
 * (La page /mentions-legales sera créée dans une tranche ultérieure.)
 */
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__name">Chewbackk Studio</span>
      <p class="footer__tagline">
        Développement web sur mesure - sites, applications, automatisations.
      </p>
    </div>

    <nav class="footer__nav" aria-label="Pied de page">
      <a href="/services">Services</a>
      <a href="/realisations">Réalisations</a>
      <a href="/contact">Contact</a>
      <a href="/mentions-legales">Mentions légales</a>
    </nav>
  </div>

  <div class="container footer__legal">
    <p>© {year} <a href="https://evanbouvier.fr" target="_blank" rel="noopener noreferrer">Evan Bouvier</a> - Chewbackk Studio.</p>
    <p>TVA non applicable, art. 293 B du CGI.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--c-line);
    padding-block: var(--sp-12) var(--sp-8);
    margin-top: var(--section-pad);
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-8);
    justify-content: space-between;
    align-items: flex-start;
  }

  .footer__name {
    font-family: var(--font-display);
    font-size: var(--fs-step-1);
  }

  .footer__tagline {
    margin-top: var(--sp-2);
    max-width: 38ch;
    color: var(--c-ink-muted);
    font-size: var(--fs-step--1);
  }

  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-6);
  }

  .footer__nav a {
    color: var(--c-ink-muted);
    text-decoration: none;
  }
  .footer__nav a:hover {
    color: var(--c-ink);
  }

  .footer__legal {
    margin-top: var(--sp-8);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-6);
    color: var(--c-ink-muted);
    font-size: var(--fs-step--1);
  }

  .footer__legal a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .footer__legal a:hover {
    color: var(--c-ink);
  }
</style>
