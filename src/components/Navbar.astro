---
/**
 * Navbar.astro - chrome de navigation (stub pour la tranche 1).
 * `transition:persist` : la barre n'est pas re-rendue/animée entre les
 * navigations ClientRouter. Le skip-link cible le <main> du layout (#contenu).
 */
const links = [
  { href: "/services", label: "Services" },
  { href: "/realisations", label: "Réalisations" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<a class="skip-link" href="#contenu">Aller au contenu</a>

<header class="nav" transition:persist>
  <div class="nav__scrim" data-nav-scrim aria-hidden="true"></div>
  <div class="container nav__inner">
    <a class="nav__brand" href="/" aria-label="Chewbackk Studio - accueil">
      <span class="nav__brand-name">Chewbackk</span>
      <span class="nav__brand-tag">studio</span>
    </a>

    <nav aria-label="Navigation principale">
      <ul class="nav__list" id="nav-menu-list" data-nav-list>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      class="nav__burger"
      type="button"
      aria-expanded="false"
      aria-controls="nav-menu-list"
      aria-label="Ouvrir le menu"
      data-nav-burger
    >
      <span class="nav__burger-bar" aria-hidden="true"></span>
      <span class="nav__burger-bar" aria-hidden="true"></span>
      <span class="nav__burger-bar" aria-hidden="true"></span>
    </button>

    <a class="nav__cta" href="/contact">
      <span class="nav__cta-full">Démarrer un projet</span>
      <span class="nav__cta-short">Projet</span>
    </a>
  </div>
</header>

<script>
  import { bootstrapNavMenu } from "../scripts/nav-menu";
  bootstrapNavMenu();
</script>

<style>
  /* Header ferme : fond noir solide (pas de glass), bord franc + filet
     d'accent net en bas. Cohérent avec le parti pris tranchant du site. */
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: var(--c-bg);
    border-bottom: 1px solid var(--c-line);
    box-shadow: 0 1px 0 0 var(--c-accent); /* filet d'accent net sous le bord */
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
    min-height: var(--nav-h);
  }

  /* Voile sous le menu mobile ouvert : la page passe en retrait, le
     dropdown reste le seul plan lisible (sans lui, le hero et son plan
     restaient à pleine luminosité sous les liens). Enfant du header :
     sticky ne crée pas de containing block pour fixed, le voile couvre
     bien le viewport ; z-index -1 le met sous la barre et le dropdown
     dans la pile locale du header (elle-même au-dessus de la page). */
  .nav__scrim {
    display: none;
    position: fixed;
    inset: 0;
    z-index: -1;
    background: rgba(var(--c-bg-rgb), 0.78);
  }
  .nav__scrim.is-open {
    display: block;
  }

  /* Logotype verrouillé : « Chewbackk » (Archivo) + label mono « studio ».
     La même écriture partout (nav, hero, footer, title). Pas d'accent ici :
     le vert est réservé au hero (signature + CTA). */
  .nav__brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-2);
    color: var(--c-ink);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav__brand-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--fs-step-1);
    letter-spacing: -0.02em;
  }
  .nav__brand-tag {
    font-family: var(--font-mono);
    font-size: 0.7em;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--c-ink-muted);
  }

  .nav__list {
    display: flex;
    gap: var(--sp-8);
    list-style: none;
    padding: 0;
  }

  /* Liens fermes : capitales, interlettrage, et un repère carré d'accent
     sous le lien actif / au survol (au lieu d'un simple changement de teinte). */
  .nav__list a {
    position: relative;
    color: var(--c-ink-muted);
    text-decoration: none;
    font-size: var(--fs-step--1);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding-block: var(--sp-2);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav__list a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 2px;
    background: var(--c-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .nav__list a:hover,
  .nav__list a[aria-current="page"] {
    color: var(--c-ink);
  }
  .nav__list a:hover::after,
  .nav__list a[aria-current="page"]::after {
    transform: scaleX(1);
  }

  /* CTA nav en ghost : contour discret, se remplit d'accent au survol.
     Le vert plein est réservé au CTA du hero (accent rationné). */
  .nav__cta {
    margin-left: auto;
    padding: 0.7rem var(--sp-6);
    background: transparent;
    color: var(--c-ink);
    border: 1px solid var(--c-line);
    border-radius: var(--r-sm);
    font-size: var(--fs-step--1);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .nav__cta:hover {
    background: var(--c-accent);
    color: var(--c-accent-ink);
    border-color: var(--c-accent);
  }
  /* Label court sous 640px (le hero porte déjà le CTA long). */
  .nav__cta-short {
    display: none;
  }

  /* Bouton burger : caché en desktop, affiché sous 640px (cf. media query).
     Trois barres qui se transforment en croix via .is-open (posée par
     nav-menu.ts sur le clic, cf. aria-expanded en écho). */
  .nav__burger {
    display: none;
    flex: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }
  .nav__burger-bar {
    display: block;
    width: 1.35rem;
    height: 2px;
    background: var(--c-ink);
    transition:
      transform var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }
  .nav__burger.is-open .nav__burger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__burger.is-open .nav__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .nav__burger.is-open .nav__burger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Sous 640px : les liens centraux passent dans le menu burger (déroulant
     sous la nav, pleine largeur). Marque + CTA restent visibles dans le
     bandeau. Le footer expose aussi toute la navigation, en secours. */
  @media (max-width: 640px) {
    .nav__list {
      display: none;
    }
    .nav__list.is-open {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      gap: 0;
      background: var(--c-bg);
      border-bottom: 1px solid var(--c-line);
      padding: 0 var(--container-pad) var(--sp-4);
    }
    .nav__list.is-open li {
      border-top: 1px solid var(--c-line);
    }
    .nav__list.is-open li:first-child {
      border-top: none;
    }
    .nav__list.is-open a {
      display: block;
      padding-block: var(--sp-4);
      font-size: var(--fs-step-0);
    }
    .nav__burger {
      display: flex;
    }
    .nav__cta {
      padding: var(--sp-2) var(--sp-4);
    }
    .nav__cta-full {
      display: none;
    }
    .nav__cta-short {
      display: inline;
    }
  }

  /* Sous 420px : on resserre fort pour éviter tout débordement horizontal
     (marque + burger + CTA doivent tenir dans 320px : mesuré, avec le tag
     « studio » et les gaps sp-3 la barre débordait de 27px). */
  @media (max-width: 420px) {
    .nav__inner {
      gap: var(--sp-2);
    }
    .nav__brand-tag {
      display: none;
    }
    .nav__brand {
      font-size: var(--fs-step-0);
    }
    .nav__cta {
      padding: var(--sp-2) var(--sp-3);
      font-size: var(--fs-step--1);
      letter-spacing: 0.04em;
    }
  }
</style>
